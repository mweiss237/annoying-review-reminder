{
  "name": "annoying-review-reminder",
  "displayName": "Annoying Review Reminder",
  "description": "Brutally reminds you about pending PR reviews with escalating annoyance levels — from gentle nudges to full-screen chaos.",
  "version": "0.3.0",
  "publisher": "mweiss237",
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "pull-request",
    "review",
    "reminder",
    "notification"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "annoyingReviewReminder.refresh",
        "title": "Refresh Pending Reviews",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.showReviews",
        "title": "Show Pending Reviews",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.togglePause",
        "title": "Pause / Resume Reminders",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.snooze",
        "title": "Snooze All Reminders",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.resetEscalation",
        "title": "Reset Escalation & Restore Colors",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.selectRepos",
        "title": "Select Repositories to Watch",
        "category": "Review Reminder"
      },
      {
        "command": "annoyingReviewReminder.promiseToReview",
        "title": "I Promise to Review! (Stop Nuclear)",
        "category": "Review Reminder"
      }
    ],
    "configuration": {
      "title": "Annoying Review Reminder",
      "properties": {
        "annoyingReviewReminder.repos": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of GitHub repositories to watch (e.g. [\"owner/repo\"]). Leave empty to watch all repos where you have pending reviews."
        },
        "annoyingReviewReminder.pollIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "How often to check for pending reviews (in seconds)."
        },
        "annoyingReviewReminder.maxBrutalityLevel": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum brutality level (0=Gentle, 1=Nudge, 2=Pushy, 3=Intrusive, 4=Aggressive, 5=Nuclear)."
        },
        "annoyingReviewReminder.snoozeDurationMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "How long to snooze reminders (in minutes)."
        },
        "annoyingReviewReminder.snoozeEscalationThresholdMinutes": {
          "type": "number",
          "default": 120,
          "minimum": 1,
          "description": "How long (in minutes) a user can keep snoozing before the reminder escalates to the next level."
        },
        "annoyingReviewReminder.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the review reminder."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "node esbuild.mjs --minify",
    "vscode:prepublish": "npm run package",
    "lint": "eslint src --ext ts",
    "create:vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
